<idea-plugin>
    <id>com.github.amitcodr.worksonmymachine</id>
    <name>WorksOnMyMachine</name>
    <vendor>amitcodr</vendor>

    <description>
        Plays customizable sound effects on Build Success, Build Failure,
        Run Success, and Runtime Exceptions in Android Studio.
    </description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity implementation="com.github.amitcodr.worksonmymachine.startup.PluginStartup"/>
        <applicationService serviceImplementation="com.github.amitcodr.worksonmymachine.settings.SettingsState"/>
        <applicationConfigurable instance="com.github.amitcodr.worksonmymachine.settings.SettingsConfigurable"/>
    </extensions>

</idea-plugin>